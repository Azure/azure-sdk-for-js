{
  "extends": "./tsconfig.src.build.json",
  "compilerOptions": {
    "outDir": "${configDir}/dist/commonjs",
    "rootDir": "${configDir}/src",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "#platform/*": ["${configDir}/src/*.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["${configDir}/src/**/*.ts", "${configDir}/src/**/*.cts"]
}

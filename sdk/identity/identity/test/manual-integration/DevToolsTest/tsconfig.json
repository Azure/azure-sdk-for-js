{
    "compilerOptions": {
      "target": "ES2020",
      "module": "Node16",
      "moduleResolution": "Node16",
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "alwaysStrict": true,
      "outDir": "dist",
      "rootDir": "src"
    },
    "include": [
      "src/**/*.ts"
    ]
}
{
  "name": "@azure/identity-cache-persistence",
  "version": "1.3.1",
  "sdk-type": "client",
  "description": "A secure, persistent token cache for Azure Identity credentials that uses the OS secret-management API",
  "main": "./dist/commonjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "scripts": {
    "build": "npm run clean && dev-tool run build-package && dev-tool run extract-api",
    "build:samples": "tsc -p config/tsconfig.samples.json",
    "check-format": "prettier --list-different --config ../../../.prettierrc.json --ignore-path ../../../.prettierignore \"src/**/*.{ts,cts,mts}\" \"test/**/*.{ts,cts,mts}\" \"*.{js,cjs,mjs,json}\" \"samples-dev/**/*.{ts,cts,mts}\"",
    "clean": "rimraf --glob dist dist-* types *.tgz *.log",
    "execute:samples": "echo skipped",
    "extract-api": "dev-tool run build-package && dev-tool run extract-api",
    "format": "prettier --write --config ../../../.prettierrc.json --ignore-path ../../../.prettierignore \"src/**/*.{ts,cts,mts}\" \"test/**/*.{ts,cts,mts}\" \"*.{js,cjs,mjs,json}\" \"samples-dev/**/*.{ts,cts,mts}\"",
    "lint": "eslint package.json src test",
    "lint:fix": "eslint package.json src test --fix --fix-type [problem,suggestion]",
    "pack": "pnpm pack 2>&1",
    "test": "tsc -b --noEmit && npm run test:node && npm run test:browser",
    "test:browser": "echo skipped",
    "test:node": "echo skipped",
    "update-snippets": "dev-tool run update-snippets"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Azure/azure-sdk-for-js",
    "directory": "sdk/identity/identity-cache-persistence"
  },
  "keywords": [
    "azure",
    "cloud",
    "active directory",
    "authentication",
    "credential",
    "certificate",
    "persistence",
    "cache"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Azure/azure-sdk-for-js/issues"
  },
  "homepage": "https://github.com/Azure/azure-sdk-for-js/tree/main/sdk/identity/identity-cache-persistence/README.md",
  "sideEffects": false,
  "imports": {
    "#platform/*": {
      "browser": "./src/*-browser.mts",
      "default": "./src/*.ts"
    }
  },
  "dependencies": {
    "@azure/core-auth": "^1.9.0",
    "@azure/identity": "^4.7.0",
    "@azure/msal-node": "^5.1.0",
    "@azure/msal-node-extensions": "^5.1.0",
    "keytar": "^7.6.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@azure-tools/test-recorder": "workspace:^",
    "@azure-tools/test-utils-vitest": "workspace:^",
    "@azure/core-client": "^1.9.2",
    "@azure/dev-tool": "workspace:^",
    "@azure/eslint-plugin-azure-sdk": "workspace:^",
    "@azure/logger": "^1.1.4",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:testing",
    "@vitest/coverage-istanbul": "catalog:testing",
    "cross-env": "catalog:",
    "dotenv": "catalog:testing",
    "eslint": "catalog:",
    "playwright": "catalog:testing",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:testing"
  },
  "type": "module",
  "browser": "./dist/browser/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    }
  }
}

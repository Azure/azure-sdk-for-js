{
  "displayNames": {
    "**/test-results.xml": ""
  },
  "matrix": {
    "Agent": {
      "windows-2022": {
        "OSVmImage": "env:WINDOWSVMIMAGE",
        "Pool": "env:WINDOWSPOOL",
        "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "true"
      },
      "ubuntu-20.04": {
        "OSVmImage": "env:LINUXVMIMAGE",
        "Pool": "env:LINUXPOOL",
        "AZURE_TEST_AGENT": "UBUNTU_2004_NODE14",
        "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "false"
      },
      "macos-latest": {
        "OSVmImage": "env:MACVMIMAGE",
        "Pool": "env:MACPOOL",
        "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "true"
      }
    },
    "NodeTestVersion": ["env:NODE_VERSION_N2", "env:NODE_VERSION_N1"],
    "TestType": "node",
    "TestResultsFiles": "**/test-results.xml"
  },
  "include": [
    {
      "Agent": {
        "windows-2022": {
          "OSVmImage": "env:WINDOWSVMIMAGE",
          "Pool": "env:WINDOWSPOOL"
        }
      },
      "Scenario": {
        "coverage": {
          "TestType": "node",
          "TestResultsFiles": "**/test-results.xml",
          "PublishCodeCoverage": "true",
          "AZURE_TEST_AGENT": "WINDOWS_2019_NODE14",
          "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "false"
        },
        "sample": {
          "TestType": "sample",
          "TestResultsFiles": "**/test-results.xml",
          "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "true"
        },
        "browser": {
          "TestType": "browser",
          "TestResultsFiles": "**/test-results.browser.xml",
          "AZURE_TEST_AGENT": "WINDOWS_2019_BROWSER",
          "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "false"
        }
      },
      "NodeTestVersion": "env:NODE_VERSION_N2"
    },
    {
      "Agent": {
        "ubuntu-20.04": {
          "OSVmImage": "env:LINUXVMIMAGE",
          "Pool": "env:LINUXPOOL"
        }
      },
      "TestType": "node",
      "NodeTestVersion": "env:NODE_VERSION_N2",
      "DependencyVersion": ["max", "min"],
      "TestResultsFiles": "**/test-results.xml",
      "SKIP_UPDATE_CAPABILITIES_LIVE_TESTS": "true"
    }
  ]
}

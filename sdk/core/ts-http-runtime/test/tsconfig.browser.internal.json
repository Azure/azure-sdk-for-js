{
  "extends": "../../../../tsconfig.browser.base.json",
  "compilerOptions": {
    "outDir": "../dist-test/browser",
    "paths": {
      "@typespec/ts-http-runtime": ["../dist/browser/index.d.ts"],
      "@typespec/ts-http-runtime/*": ["../dist/browser/*"],
      "$internal/*": ["../dist/browser/*"]
    },
    "customConditions": ["browser"]
  },
  "include": ["./browser/**/*.ts"],
  "exclude": [
    "../src",
    "./**/node",
    "./snippets.spec.ts",
    "./browser/logger.spec.ts",
    "./browser/streams.spec.ts"
  ]
}

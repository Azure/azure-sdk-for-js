{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "importHelpers": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "types": ["node"],
    "outDir": "./dist",
    "resolveJsonModule": true,
    "moduleResolution": "node10"
  },
  "include": [
    "./src"
  ]
}

{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "importHelpers": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "moduleResolution": "nodenext"
  },
  "include": [
    "./src"
  ]
}

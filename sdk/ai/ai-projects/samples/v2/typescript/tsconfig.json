{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "importHelpers": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "NodeNext",
    "paths": {
      "@azure/ai-projects": [
        "../../../dist/esm/index.d.ts",
        "./node_modules/@azure/ai-projects/dist/esm/index.d.ts"
      ],
      "openai": [
        "./node_modules/openai/index.d.mts"
      ],
      "openai/*": [
        "./node_modules/openai/*.d.mts"
      ]
    },
    "esModuleInterop": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "resolveJsonModule": true
  },
  "include": [
    "./src"
  ]
}

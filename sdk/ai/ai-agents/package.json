      },
      "require": {
        "types": "./dist/commonjs/models/index.d.ts",
        "default": "./dist/commonjs/models/index.js"
      }
    }
  },
  "//sampleConfiguration": {
    "productName": "Azure AI Agents",
    "productSlugs": ["azure"],
    "extraFiles": {
      "./data": ["javascript/data", "typescript/data"]
    },
    "apiRefLink": "https://learn.microsoft.com/javascript/api/@azure/ai-projects"
  },
  "main": "./dist/commonjs/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "module": "./dist/esm/index.js",
  "homepage": "https://github.com/Azure/azure-sdk-for-js/tree/main/sdk/ai/ai-agents/README.md",
  "imports": {
    "#platform/*": {
      "browser": "./src/*-browser.mts",
      "default": "./src/*.ts"
    }
  }
}

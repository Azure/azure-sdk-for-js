        "default": "./dist/esm/api/vectorStoreFiles/index.js"
      },
      "require": {
        "types": "./dist/commonjs/api/vectorStoreFiles/index.d.ts",
        "default": "./dist/commonjs/api/vectorStoreFiles/index.js"
      }
    },
    "./api/vectorStores": {
      "browser": {

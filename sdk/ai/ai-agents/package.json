        "default": "./dist/esm/api/runs/index.js"
      },
      "require": {
        "types": "./dist/commonjs/api/runs/index.d.ts",
        "default": "./dist/commonjs/api/runs/index.js"
      }
    },
    "./api/messages": {
      "browser": {
        "types": "./dist/browser/api/messages/index.d.ts",
        "default": "./dist/browser/api/messages/index.js"
      },
      "import": {
        "types": "./dist/esm/api/messages/index.d.ts",
        "default": "./dist/esm/api/messages/index.js"
      },
      "require": {
        "types": "./dist/commonjs/api/messages/index.d.ts",
        "default": "./dist/commonjs/api/messages/index.js"
      }
    },
    "./api/threads": {
      "browser": {
        "types": "./dist/browser/api/threads/index.d.ts",
        "default": "./dist/browser/api/threads/index.js"
      },
      "import": {

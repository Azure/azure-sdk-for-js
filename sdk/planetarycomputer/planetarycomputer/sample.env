# The endpoint of your GeoCatalog resource.
# Create a GeoCatalog in the Azure Portal and enter its endpoint URI here.
PLANETARYCOMPUTER_ENDPOINT=<geocatalog-endpoint>

# The STAC collection ID to use in the tests (e.g. "naip-atl").
PLANETARYCOMPUTER_COLLECTION_ID=<collection-id>

# The STAC item ID to use in the tests (e.g. "ga_m_3308421_se_16_060_20211114").
PLANETARYCOMPUTER_ITEM_ID=<item-id>

# (Optional) For ingestion tests - Azure Blob Storage container URI with source data.
PLANETARYCOMPUTER_INGESTION_CONTAINER_URI=<ingestion-container-uri>

# (Optional) For ingestion tests - URL to the STAC catalog JSON for ingestion.
PLANETARYCOMPUTER_INGESTION_CATALOG_URL=<ingestion-catalog-url>

# (Optional) For ingestion tests - Object ID of the managed identity to use.
PLANETARYCOMPUTER_MANAGED_IDENTITY_OBJECT_ID=<managed-identity-object-id>

# (Optional) For SAS token ingestion tests - Azure Blob Storage container URI.
PLANETARYCOMPUTER_INGESTION_SAS_CONTAINER_URI=<sas-container-uri>

# (Optional) For SAS token ingestion tests - SAS token for the container.
PLANETARYCOMPUTER_INGESTION_SAS_TOKEN=<sas-token>

# Our tests assume that TEST_MODE is "playback" by default. You can
# change it to "record" to generate new recordings, or "live" to bypass the recorder entirely.
# TEST_MODE=playback

# Azure Speech Transcription Test Configuration
# Copy this file to .env and fill in your values.

# Required: The endpoint URL for the Azure Speech Transcription service
# Example: https://eastus.api.cognitive.microsoft.com
TRANSCRIPTION_ENDPOINT=https://your-region.api.cognitive.microsoft.com

# Required: Your API key for authentication (keep this secret!)
TRANSCRIPTION_API_KEY=your-api-key-here

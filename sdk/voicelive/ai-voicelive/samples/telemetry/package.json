{
  "name": "voicelive-telemetry-sample",
  "version": "1.0.0",
  "description": "Demonstrates OpenTelemetry tracing with the Azure Voice Live SDK",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "start": "npx tsx --import ./preload.mts index.ts",
    "start:agent": "npx tsx --import ./preload.mts agentTelemetry.ts"
  },
  "dependencies": {
    "@azure/ai-voicelive": "file:../../",
    "@azure/abort-controller": "^2.1.0",
    "@azure/core-auth": "^1.9.0",
    "@azure/core-rest-pipeline": "^1.20.0",
    "@azure/core-util": "^1.12.0",
    "@azure/logger": "^1.2.0",
    "@azure/identity": "^4.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-node": "^1.25.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "~5.9.3"
  }
}

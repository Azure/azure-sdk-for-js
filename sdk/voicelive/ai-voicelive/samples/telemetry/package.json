  "description": "Node.js telemetry sample for Azure Voice Live SDK — console and Azure Monitor tracing",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:monitor": "node dist/azure-monitor.js",
    "dev": "tsc && node dist/index.js"
  },
  "dependencies": {
    "@azure/ai-voicelive": "file:../../azure-ai-voicelive-1.0.0-beta.4.tgz",
    "@azure/core-auth": "^1.9.0",

    "@azure/identity": "^4.0.0",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.28",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/sdk-trace-node": "^2.0.0"

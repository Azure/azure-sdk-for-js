{
  "name": "basic-web-voice-assistant",
  "version": "1.0.0",
  "description": "A simple web-based voice assistant demonstrating Azure Voice Live SDK real-time features",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "vite",
    "dev-sdk": "vite --force",
    "preview": "vite preview",
    "serve": "python -m http.server 8080",
    "type-check": "tsc --noEmit",
    "reload": "curl -X POST http://localhost:3000/__vite_ping 2>/dev/null || echo 'Vite server not responding'"
  },
  "dependencies": {
    "@azure/ai-voicelive": "file:../../",
    "@azure/abort-controller": "^2.1.0",
    "@azure/core-auth": "^1.9.0",
    "@azure/core-rest-pipeline": "^1.20.0",
    "@azure/core-util": "^1.12.0",
    "@azure/logger": "^1.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.9.3",
    "vite": "^5.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}

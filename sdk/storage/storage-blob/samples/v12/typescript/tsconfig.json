{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "lib": [
      "ESNext"
    ],
    "importHelpers": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": [
      "node"
    ],
    "allowJs": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "moduleResolution": "nodenext"
  },
  "include": [
    "./src"
  ]
}

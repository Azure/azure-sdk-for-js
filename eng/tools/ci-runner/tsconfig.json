{
  "compilerOptions": {
    "allowJs": true,
    "noEmit": true,
    "target": "ES2023",
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["index.js", "src/**/*.js", "test/**/*.js"]
}

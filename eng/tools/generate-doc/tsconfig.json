{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "lib": ["ESNext"],
    "types": ["node"],
    "alwaysStrict": true,
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "jsx": "react",
    "jsxFactory": "JSX.createElement",
    "jsxFragmentFactory": "JSX.Fragment",
    "outDir": "dist"
  }
}

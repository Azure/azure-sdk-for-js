{
  "name": "typescript-codegen-breaking-change-detector",
  "version": "0.7.11",
  "description": "Detect breaking changes to your TypeScript client generated by open api, typespec and more...",
  "main": "dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "build:watch": "rimraf ./dist && tsc --watch",
    "start": "npm run build && node dist/index.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "prettier-format": "prettier --write .",
    "prettier-format:check": "prettier --check ."
  },
  "license": "MIT",
  "dependencies": {
    "@typescript-eslint/parser": "^8.62.1",
    "@typescript-eslint/scope-manager": "^8.62.1",
    "@typescript-eslint/types": "^8.62.1",
    "@typescript-eslint/typescript-estree": "^8.62.1",
    "@typescript-eslint/utils": "^8.62.1",
    "@typescript-eslint/visitor-keys": "^8.62.1",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.6",
    "marked": "^18.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ts-morph": "^28.0.0",
    "typescript-eslint": "^8.62.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "prettier": "^3.8.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  }
}
